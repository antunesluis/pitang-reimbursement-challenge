                                "packages": {},
                                "requests": {},
                                "exec": [
                                    "const response = pm.response.json();",
                                    "if (response.token) {",
                                    "    pm.collectionVariables.set('token', response.token);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                                "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"admin123\"\n}",
                            "options": { "raw": { "language": "json" } }
                        },
                        "url": {
